{%- style -%}

#shopify-section-{{ section.id }} {
  background-color: {{ section.settings.image-with-content_background_color }};
  display: flex;
  flex-direction: column;
  align-items: center;
}

#shopify-section-{{ section.id }} .wl_image-with-content {
  display: flex;
  padding-top: 64px;
  max-width: 1920px;
  width: 100%;
}

#shopify-section-{{ section.id }} .wl_image-with-content.image-with-content_image-first {
  flex-direction: row;
}

#shopify-section-{{ section.id }} .wl_image-with-content.image-with-content_text-first {
  flex-direction: row-reverse;
}

#shopify-section-{{ section.id }} .wl_image-with-content_img-col {
  width: 50%;
  background-position: center;
  background-size: cover;
  background-repeat: no-repeat;
  min-height: 510px;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content-col {
  width: 50%;
  min-width: 640px;
  background-color: {{ section.settings.image-with-content_background_color }};
  padding: 96px 56px 96px 40px; /* reduced left gap */
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 24px;
  min-height: 510px;
}

#shopify-section-{{ section.id }} .wl_image-with-content_heading {
  color: {{ section.settings.image-with-content_heading_color }};
  font-family: Sora;
  font-size: 32px;
  font-weight: 300;
  line-height: 110%;
  max-width: 448px;
  width: 100%;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content {
  color: {{ section.settings.image-with-content_text_color }};
  font-family: Sora;
  font-size: 16px;
  font-weight: 400;
  line-height: 175%;
  max-width: 448px;
  width: 100%;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content a {
  margin-top: 24px;
  color: {{ section.settings.image-with-content_text_color }};
  font-family: Sora;
  font-size: 16px;
  font-weight: 700;
  text-decoration: underline;
  display: block;
  transition: opacity 0.3s ease;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content a:hover {
  opacity: 0.75;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content a.wl_button {
  padding: 20px 24px;
  font-family: Sora;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.32px;
  text-transform: uppercase;
  text-decoration: none !important;
  min-width: fit-content;
  margin-top: 48px !important;
  transition: background 0.3s ease;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content a.wl_button-beige {
  background: #E9DDC6;
  color: #154734 !important;
}

#shopify-section-{{ section.id }} .wl_image-with-content_content a.wl_button-beige:hover {
  background: #E9DDC680;
}

#shopify-section-{{ section.id }} .wl_image-with-content_preimage {
  height: 70px !important;
  max-width: 100% !important;
}

#shopify-section-{{ section.id }} .wl_button.btn-1 {
  background: #154734;
  padding: 20px 48px;
  color: #e9ddc6;
  font-family: Sora;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.32px;
  text-transform: uppercase;
  text-decoration: none;
  margin-top: 20px;
  transition: background 0.3s ease;
  width: fit-content;
}

#shopify-section-{{ section.id }} .wl_button.btn-1:hover {
  background: #15473480;
}

@media (max-width: 1024px) {
  #shopify-section-{{ section.id }} .wl_image-with-content_content-col {
    padding: 48px 32px;
    min-width: 500px;
  }
}

@media (max-width: 767px) {
  #shopify-section-{{ section.id }} .wl_image-with-content {
    flex-direction: column;
    padding-top: 0;
  }

  #shopify-section-{{ section.id }} .wl_image-with-content_content-col {
    width: 100%;
    padding: 60px 20px;
    min-width: unset;
  }

  #shopify-section-{{ section.id }} .wl_image-with-content_img-col {
    width: 100%;
    min-height: 320px;
  }

  #shopify-section-{{ section.id }} .wl_image-with-content_heading {
    font-size: 24px;
  }

  #shopify-section-{{ section.id }} .wl_image-with-content_content {
    font-size: 14px;
  }
}

{%- endstyle -%}
