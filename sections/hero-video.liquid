{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.hero-video_background_color }};
  }

  #shopify-section-{{ section.id }} .wl_hero-video {
    height: 90vh;
    display: flex;
    position: relative;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .wl_hero-video::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: rgba(21, 71, 52, 0.25);
    background-image: url(https://cdn.shopify.com/s/files/1/0716/3884/3606/files/squiggles-green-light.svg?v=1733883814);
    background-position: bottom right;
    background-repeat: no-repeat;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 90vh;
    object-fit: cover;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_image {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_wrapper {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
    align-items: end;
    justify-items: start;
    width: 100%;
    margin: 0 auto;
    padding: 20px 20px 96px 20px;
    max-width: 1280px;
    z-index: 2;
    height: 90vh;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_inner {
    grid-column: 1 / -1;
    display: flex;
    max-width: 590px;
    flex-direction: column;
    align-items: flex-start;
    gap: 40px;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_subheading {
    color: {{ section.settings.hero-video_subheading_color }};
    font-family: Sora;
    font-size: 12px;
    font-weight: 700;
    line-height: 100%;
    letter-spacing: 0.24px;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_heading {
    color: {{ section.settings.hero-video_heading_color }};
    font-family: Sora;
    font-size: 64px;
    font-weight: 300;
    line-height: 110%;
    text-transform: capitalize;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_button {
    background: #E9DDC6;
    padding: 20px 24px;
    color: #154734;
    text-align: center;
    font-family: Sora;
    font-size: 16px;
    font-weight: 700;
    line-height: 100%;
    letter-spacing: 0.32px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s ease;
  }

  #shopify-section-{{ section.id }} .wl_hero-video_button:hover {
    background: #E9DDC680;
  }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .wl_hero-video_wrapper {
      padding: 60px 20px;
    }

    #shopify-section-{{ section.id }} .wl_hero-video_heading {
      font-size: 32px;
    }

    #shopify-section-{{ section.id }} .wl_hero-video_button {
      font-size: 14px;
    }
  }
{%- endstyle -%}


<div class="wl_hero-video">

  {% if section.settings.hero-video_media_type == 'video' and section.settings.hero-video_video != blank %}
    
    <video
      class="wl_hero-video_media"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      {% if section.settings.hero-video_video.preview_image %}
        poster="{{ section.settings.hero-video_video.preview_image | image_url }}"
      {% endif %}
    >
      {% for source in section.settings.hero-video_video.sources %}
        <source src="{{ source.url }}" type="{{ source.mime_type }}">
      {% endfor %}
    </video>

  {% elsif section.settings.hero-video_media_type == 'image' and section.settings.hero-video_image != blank %}

    <div
      class="wl_hero-video_media wl_hero-video_image"
      style="background-image: url('{{ section.settings.hero-video_image | image_url: width: 2000 | prepend: 'https:' }}');"
    ></div>

  {% endif %}

  <div class="wl_hero-video_wrapper">
    <div class="wl_hero-video_inner">

      {% if section.settings.hero-video_subheading != blank %}
        <h5 class="wl_hero-video_subheading">
          {{ section.settings.hero-video_subheading }}
        </h5>
      {% endif %}

      {% if section.settings.hero-video_heading != blank %}
        <h1 class="wl_hero-video_heading">
          {{ section.settings.hero-video_heading }}
        </h1>
      {% endif %}

      {% if section.settings.hero-video_button-url != blank %}
        <a href="{{ section.settings.hero-video_button-url }}" class="wl_hero-video_button">
          {{ section.settings.hero-video_button-text }}
        </a>
      {% endif %}

    </div>
  </div>
</div>


{% schema %}
{
  "name": "Hero Media",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "hero-video_media_type",
      "label": "Background Type",
      "options": [
        { "value": "video", "label": "Video" },
        { "value": "image", "label": "Image" }
      ],
      "default": "video"
    },
    {
      "type": "video",
      "id": "hero-video_video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "hero-video_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "hero-video_subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "hero-video_heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "hero-video_button-text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "hero-video_button-url",
      "label": "Button URL"
    },
    {
      "type": "select",
      "id": "hero-video_subheading_color",
      "label": "Subheading Color",
      "options": [
        { "value": "#E9DDC680", "label": "Beige - 50%" },
        { "value": "#15473480", "label": "Green - Dark - 50%" }
      ],
      "default": "#E9DDC680"
    },
    {
      "type": "select",
      "id": "hero-video_heading_color",
      "label": "Heading Color",
      "options": [
        { "value": "#E9DDC6", "label": "Beige" },
        { "value": "#154734", "label": "Green - Dark" }
      ],
      "default": "#E9DDC6"
    },
    {
      "type": "select",
      "id": "hero-video_background_color",
      "label": "Background Color",
      "options": [
        { "value": "#154734", "label": "Green - Dark" },
        { "value": "#FFF5E5", "label": "Beige - Light" }
      ],
      "default": "#154734"
    }
  ],
  "presets": [
    {
      "name": "Hero Media"
    }
  ]
}
{% endschema %}