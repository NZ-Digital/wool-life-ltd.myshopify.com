{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color | default: "#154734" }};
    color: {{ section.settings.text_color | default: "#E9DDC6" }};
  }

  #shopify-section-{{ section.id }} .wl-hero {
    padding: 96px 20px;
  }

  #shopify-section-{{ section.id }} .wl-hero__inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  #shopify-section-{{ section.id }} .wl-hero__row {
    display: flex;
    align-items: flex-start;
    gap: 52px; 
  }

  #shopify-section-{{ section.id }} .wl-hero__content {
    max-width: 720px; 
  }

  #shopify-section-{{ section.id }} .wl-hero__heading {
    margin: 0 0 20px 0;
    font-family: Sora, sans-serif;
    font-weight: 300;
    font-size: 72px;
    line-height: 1.05;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .wl-hero__subtext {
    margin: 0;
    max-width: 560px; 
    font-family: Sora, sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 1.6;
    color: rgba(233, 221, 198, 0.8);
  }

  /* Badge column */
  #shopify-section-{{ section.id }} .wl-hero__badgeWrap {
    flex: 0 0 auto;
    width: {{ section.settings.badge_size | default: 160 }}px;
  }

  #shopify-section-{{ section.id }} .wl-hero__badge {
    display: block;
    width: 100%;
    height: auto;
    border: 0;
    outline: 0;
    box-shadow: none;
    background: transparent;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .wl-hero__heading { font-size: 56px; }
    #shopify-section-{{ section.id }} .wl-hero__row { gap: 30px; }
    #shopify-section-{{ section.id }} .wl-hero__content { max-width: 440px; }
  }
  #shopify-section-{{ section.id }} .wl-hero__heading {
  display: flex;
  flex-direction: column;
  gap: 0;  
  line-height: 1.05;
}

#shopify-section-{{ section.id }} .wl-h-line {
  display: block;
}


/* Mobile */
@media (max-width: 767px) {

  #shopify-section-{{ section.id }} {
    position: relative;
  }

  #shopify-section-{{ section.id }} .wl-hero {
    padding:30px 15px 30px 15px
  }
  #shopify-section-{{ section.id }} .wl-hero__row {
    flex-direction: column !important;
    gap: 16px !important;
  }
  #shopify-section-{{ section.id }} .wl-hero__content {
    width: 90% !important;
    max-width: 90% !important;
    position: relative;
  }
  #shopify-section-{{ section.id }} .wl-hero__badgeWrap {
    position: absolute !important;
    top: -50px !important;
    right: 0px !important;
    width: {{ section.settings.badge_size_mobile | default: 140 }}px !important;
    z-index: 3;

    flex: none !important;
    margin: 0 !important;
  }

  #shopify-section-{{ section.id }} .wl-hero__heading {
    font-size: 50px;
    line-height: 1.08;
    margin-bottom: 32px;
    padding-top: 10px;
    padding-left:40px


  }

  #shopify-section-{{ section.id }} .wl-hero__subtext {
    font-size: 16px;
    max-width: 100%;
    padding-left:40px
  }
}

{%- endstyle -%}

<section class="wl-hero">
  <div class="wl-hero__inner">
    <div class="wl-hero__row">
      <div class="wl-hero__content">
        <h1 class="wl-hero__heading">{{ section.settings.heading }}</h1>
        <p class="wl-hero__subtext">{{ section.settings.subtext }}</p>
      </div>

      {%- if section.settings.badge_image != blank -%}
        <div class="wl-hero__badgeWrap">
          <img
            class="wl-hero__badge"
            src="{{ section.settings.badge_image | image_url }}"
            alt="{{ section.settings.badge_alt | escape }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WL Hero + Badge",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Mulch Matting, Made to Scale" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Bulk wool mulch mats and rolls for farms, planting projects, and large-scale use. Cost-effective. NZ-Made. Reliable Supply. 100% New Zealand wool." },

    { "type": "image_picker", "id": "badge_image", "label": "Badge image (GIF/PNG)" },
    { "type": "text", "id": "badge_alt", "label": "Badge alt text", "default": "Get bulk pricing" },

    { "type": "range", "id": "badge_size", "min": 60, "max": 480, "step": 5, "label": "Badge size (desktop)", "default": 200 },
    { "type": "range", "id": "badge_size_mobile", "min": 60, "max": 320, "step": 5, "label": "Badge size (mobile)", "default": 140 },

    { "type": "color", "id": "bg_color", "label": "Background colour", "default": "#154734" },
    { "type": "color", "id": "text_color", "label": "Text colour", "default": "#E9DDC6" }
  ],
  "presets": [
    { "name": "WL Hero + Badge" }
  ]
}
{% endschema %}
