{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__wrap {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.pad_top }}px {{ section.settings.pad_x }}px {{ section.settings.pad_bottom }}px;
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__grid {
    display: grid;
    grid-template-columns: 1fr {{ section.settings.badge_col_width }}px;
    gap: {{ section.settings.gap }}px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__title {
    margin: 0;
    font-family: {{ section.settings.heading_font | default: 'Sora' }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.05;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.02em;
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__body {
    margin-top: {{ section.settings.body_spacing }}px;
    max-width: {{ section.settings.body_max_width }}px;
    font-family: {{ section.settings.body_font | default: 'Sora' }};
    font-size: {{ section.settings.body_size }}px;
    font-weight: {{ section.settings.body_weight }};
    line-height: 1.65;
    color: {{ section.settings.body_color }};
  }

  /* Badge column */
  #shopify-section-{{ section.id }} .wl-hero-badge__badge {
    justify-self: end;
    position: relative;
    top: {{ section.settings.badge_offset_y }}px;
    right: {{ section.settings.badge_offset_x }}px;
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__badge img {
    width: {{ section.settings.badge_size }}px;
    height: auto;
    display: block;

    /* kill any theme “media” styling */
    border: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    background: transparent !important;
    border-radius: 0 !important;
  }

  #shopify-section-{{ section.id }} .wl-hero-badge__badge::before,
  #shopify-section-{{ section.id }} .wl-hero-badge__badge::after {
    content: none !important;
  }

  /* Optional faint guide column (OFF by default) */
  {% if section.settings.show_badge_guide %}
    #shopify-section-{{ section.id }} .wl-hero-badge__grid {
      background-image: linear-gradient(
        to right,
        transparent 0,
        transparent calc(100% - {{ section.settings.badge_col_width }}px),
        rgba(255,255,255,0.06) calc(100% - {{ section.settings.badge_col_width }}px),
        rgba(255,255,255,0.06) 100%
      );
      background-repeat: no-repeat;
    }
  {% endif %}

  /* Mobile */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .wl-hero-badge__grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_gap }}px;
    }

    #shopify-section-{{ section.id }} .wl-hero-badge__badge {
      justify-self: start;
      top: {{ section.settings.mobile_badge_offset_y }}px;
      right: 0;
      order: -1;
    }

    #shopify-section-{{ section.id }} .wl-hero-badge__title {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #shopify-section-{{ section.id }} .wl-hero-badge__body {
      font-size: {{ section.settings.mobile_body_size }}px;
      margin-top: {{ section.settings.mobile_body_spacing }}px;
    }
  }
{%- endstyle -%}

<div class="wl-hero-badge__wrap">
  <div class="wl-hero-badge__grid">
    <div class="wl-hero-badge__content">
      {% if section.settings.heading != blank %}
        <h2 class="wl-hero-badge__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="wl-hero-badge__body">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    {% if section.settings.badge_image != blank %}
      <div class="wl-hero-badge__badge" aria-hidden="true">
        <img
          src="{{ section.settings.badge_image | image_url }}"
          alt=""
          loading="eager"
        >
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "WL Hero + Badge",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#154734" },
    { "type": "color", "id": "text_color", "label": "Base text colour", "default": "#E9DDC6" },

    { "type": "text", "id": "heading", "label": "Heading", "default": "Mulch Matting,\nMade to Scale" },
    { "type": "color", "id": "heading_color", "label": "Heading colour", "default": "#E9DDC6" },
    { "type": "range", "id": "heading_size", "min": 28, "max": 96, "step": 1, "label": "Heading size (desktop)", "default": 64 },
    { "type": "range", "id": "heading_weight", "min": 200, "max": 800, "step": 100, "label": "Heading weight", "default": 300 },

    { "type": "richtext", "id": "body", "label": "Body copy", "default": "<p>Bulk wool mulch mats and rolls for farms, planting projects, and large-scale use. Cost-effective. NZ-Made. Reliable Supply. 100% New Zealand wool.</p>" },
    { "type": "color", "id": "body_color", "label": "Body colour", "default": "rgba(233, 221, 198, 0.80)" },
    { "type": "range", "id": "body_size", "min": 12, "max": 24, "step": 1, "label": "Body size (desktop)", "default": 16 },
    { "type": "range", "id": "body_weight", "min": 200, "max": 700, "step": 100, "label": "Body weight", "default": 400 },
    { "type": "range", "id": "body_spacing", "min": 0, "max": 40, "step": 1, "label": "Body spacing under heading", "default": 18 },
    { "type": "range", "id": "body_max_width", "min": 320, "max": 900, "step": 10, "label": "Body max width", "default": 520 },

    { "type": "image_picker", "id": "badge_image", "label": "Badge image (GIF/PNG/SVG)" },
    { "type": "range", "id": "badge_size", "min": 60, "max": 240, "step": 2, "label": "Badge size (desktop)", "default": 120 },
    { "type": "range", "id": "badge_col_width", "min": 120, "max": 420, "step": 10, "label": "Badge column width", "default": 240 },

    { "type": "range", "id": "badge_offset_x", "min": -80, "max": 80, "step": 2, "label": "Badge offset X", "default": 0 },
    { "type": "range", "id": "badge_offset_y", "min": -120, "max": 120, "step": 4, "label": "Badge offset Y", "default": 0 },

    { "type": "range", "id": "max_width", "min": 960, "max": 1600, "step": 10, "label": "Content max width", "default": 1200 },
    { "type": "range", "id": "pad_top", "min": 0, "max": 160, "step": 4, "label": "Padding top", "default": 64 },
    { "type": "range", "id": "pad_bottom", "min": 0, "max": 200, "step": 4, "label": "Padding bottom", "default": 64 },
    { "type": "range", "id": "pad_x", "min": 12, "max": 64, "step": 2, "label": "Side padding", "default": 20 },
    { "type": "range", "id": "gap", "min": 8, "max": 80, "step": 1, "label": "Desktop gap", "default": 48 },

    { "type": "header", "content": "Mobile" },
    { "type": "range", "id": "mobile_heading_size", "min": 24, "max": 64, "step": 1, "label": "Heading size (mobile)", "default": 42 },
    { "type": "range", "id": "mobile_body_size", "min": 12, "max": 20, "step": 1, "label": "Body size (mobile)", "default": 14 },
    { "type": "range", "id": "mobile_body_spacing", "min": 0, "max": 24, "step": 1, "label": "Body spacing (mobile)", "default": 14 },
    { "type": "range", "id": "mobile_gap", "min": 0, "max": 60, "step": 1, "label": "Gap (mobile)", "default": 12 },
    { "type": "range", "id": "mobile_badge_offset_y", "min": -80, "max": 80, "step": 2, "label": "Badge offset Y (mobile)", "default": 0 },

    { "type": "checkbox", "id": "show_badge_guide", "label": "Show faint badge guide column (debug)", "default": false },

    { "type": "text", "id": "heading_font", "label": "Heading font (CSS font-family)", "default": "Sora" },
    { "type": "text", "id": "body_font", "label": "Body font (CSS font-family)", "default": "Sora" }
  ],
  "presets": [
    { "name": "WL Hero + Badge" }
  ]
}
{% endschema %}
